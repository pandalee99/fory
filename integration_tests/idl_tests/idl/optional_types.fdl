package optional_types;

option rust_use_chrono_temporal_types = true;

message AllOptionalTypes [id=120] {
    optional bool bool_value = 1;
    optional int8 int8_value = 2;
    optional int16 int16_value = 3;
    optional int32 int32_value = 4;
    optional fixed int32 fixed_i32_value = 5;
    optional int32 varint_i32_value = 6;
    optional int64 int64_value = 7;
    optional fixed int64 fixed_i64_value = 8;
    optional int64 varint_i64_value = 9;
    optional tagged int64 tagged_i64_value = 10;
    optional uint8 uint8_value = 11;
    optional uint16 uint16_value = 12;
    optional uint32 uint32_value = 13;
    optional fixed uint32 fixed_u32_value = 14;
    optional uint32 varint_u32_value = 15;
    optional uint64 uint64_value = 16;
    optional fixed uint64 fixed_u64_value = 17;
    optional uint64 varint_u64_value = 18;
    optional tagged uint64 tagged_u64_value = 19;
    optional float32 float32_value = 21;
    optional float64 float64_value = 22;
    optional string string_value = 23;
    optional bytes bytes_value = 24;
    optional date date_value = 25;
    optional timestamp timestamp_value = 26;
    optional list<int32> int32_list = 27;
    optional list<string> string_list = 28;
    optional map<string, int64> int64_map = 29;
}

union OptionalUnion [id=121] {
    string note = 1;
    int32 code = 2;
    AllOptionalTypes payload = 3;
}

message OptionalHolder [id=122] {
    AllOptionalTypes all_types = 1;
    optional OptionalUnion choice = 2;
}
